# Supabase — copy this file to .env.local and fill in your project values.
# Get these from: Supabase dashboard → Project Settings → API

# Server-side only (no NEXT_PUBLIC_ prefix — never exposed to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Passphrase gate (Phase 3)
# The shared club passphrase for officer write access
NSC_WRITE_PASSPHRASE=your-passphrase

# Cookie signing secret — generate with: openssl rand -hex 32
# Rotate this to invalidate all existing sessions
NSC_COOKIE_SECRET=your-32-byte-hex-secret

# Note: if you ever need Supabase in a browser/client component, add:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
